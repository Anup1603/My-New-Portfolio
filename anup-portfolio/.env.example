# Contact form email delivery (Gmail SMTP).
#
# 1. Go to https://myaccount.google.com/apppasswords (requires 2-Step
#    Verification to be enabled on the Google account).
# 2. Create an app password named e.g. "Portfolio contact form".
# 3. Copy this file to .env.local and fill in both values.
#    On Vercel, add them under Project Settings -> Environment Variables.
GMAIL_USER=anupshaw1603@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
